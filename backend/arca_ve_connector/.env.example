# Copiar a .env (no commitear). Homologación QA por defecto.

# Entorno para la API dfe_api (y documentación): homologacion | produccion
# Alias: qa, homo → homologación | prod, production → producción
# Si no está definido, se usa homologación. Si ARCA_WSAA_URL / ARCA_VE_WSDL ya están
# definidos abajo, NO se sobrescriben.
ARCA_ENV=homologacion

# WSAA — homologación (omití estas dos líneas si usás solo ARCA_ENV y los defaults)
ARCA_WSAA_URL=https://wsaahomo.afip.gov.ar/ws/services/LoginCms
# Producción:
# ARCA_WSAA_URL=https://wsaa.afip.gov.ar/ws/services/LoginCms

# Servicio en el TRA — manual VE / WSCCOMU: veconsumerws
ARCA_WSAA_SERVICE=veconsumerws

# WSDL VEConsumer QA (homologación)
ARCA_VE_WSDL=https://stable-middleware-tecno-ext.afip.gob.ar/ve-ws/services/veconsumer?wsdl
# Producción:
# ARCA_VE_WSDL=https://infraestructura.afip.gob.ar/ve-ws/services/veconsumer?wsdl

# Certificado y clave PEM del integrador/representante delegado en ARCA
ARCA_CERT_PATH=/ruta/a/certificado.pem
ARCA_KEY_PATH=/ruta/a/private_key.pem
# Opcional: rutas distintas por entorno (ver backend/dfe_api/ENVIRONMENTS.md)
# ARCA_CERT_PATH_HOMOLOGACION=...
# ARCA_KEY_PATH_HOMOLOGACION=...
# ARCA_CERT_PATH_PRODUCCION=...
# ARCA_KEY_PATH_PRODUCCION=...

# CUIT del contribuyente cuyas comunicaciones se consultan (11 dígitos; requiere delegación al certificado de arriba)
ARCA_CUIT_REPRESENTADA=20123456789

# Depuración homologación: 1 = log TRA, subject/issuer del cert, binding Zeep, cuerpos SOAP
# ARCA_DEBUG=1

# Archivo JSON de caché del TA WSAA (opcional). Por defecto: tempfile/arca_ve_connector/wsaa_ta_cache.json
# ARCA_TA_CACHE_PATH=/ruta/ta_cache.json

# --- Solo smoke-test / probe comunicaciones (opcional) ---
# Fechas YYYY-MM-dd para consultarComunicaciones
# ARCA_SMOKE_FECHA_DESDE=2026-03-01
# ARCA_SMOKE_FECHA_HASTA=2026-04-05
# ARCA_SMOKE_PAGINA=1
# ARCA_SMOKE_RESULTADOS_POR_PAGINA=10
# Id sistema publicador (0 = probar default; si el WS rechaza, ver manual)
# ARCA_SMOKE_ID_SISTEMA_PUBLICADOR=0
