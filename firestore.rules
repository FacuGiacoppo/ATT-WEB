rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // HELPERS
    // =========================

    function isLogged() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperadmin() {
      return isLogged() && getUserRole() == "superadmin";
    }

    function isAdmin() {
      return isLogged() &&
        (getUserRole() == "superadmin" || getUserRole() == "admin");
    }

    function canColab() {
      return isLogged() &&
        (getUserRole() == "superadmin" ||
         getUserRole() == "admin" ||
         getUserRole() == "colaborador");
    }

    function clienteDfeTrue(data) {
      return 'dfeEnabled' in data && data.dfeEnabled == true;
    }

    // =========================
    // USERS
    // =========================

    match /users/{userId} {

      allow read: if isLogged();

      allow update: if isSuperadmin()
        ||
        (
          isLogged() &&
          request.auth.uid == userId &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["lastLoginAt"])
        );

      allow create, delete: if false;
    }

    // =========================
    // REQUIREMENTS
    // =========================

    match /requirements/{docId} {

      allow read: if isLogged();

      allow create: if canColab();

      allow update: if canColab();

      allow delete: if isAdmin();
    }

    // =========================
    // OPERACIONES (obligaciones / tareas)
    // =========================

    match /operaciones/{docId} {

      allow read: if isLogged();

      allow create: if canColab();

      allow update: if canColab();

      allow delete: if isAdmin();
    }

    // =========================
    // CUMPLIMIENTOS (trazabilidad)
    // =========================

    match /cumplimientos/{docId} {

      allow read: if isLogged();

      // Guardado del registro al cumplimentar
      allow create: if canColab();

      // En MVP no editamos ni borramos cumplimientos
      allow update, delete: if false;
    }

    // =========================
    // CLIENTES
    // =========================

    match /clientes/{docId} {

      allow read: if canColab();
      // Solo superadmin puede dar de alta DFE activo (delegación ARCA).
      allow create: if canColab() && (isSuperadmin() || !clienteDfeTrue(request.resource.data));
      allow update: if canColab() && (
        isSuperadmin() ||
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['dfeEnabled'])
      );

      // Solo superadmin puede eliminar
      allow delete: if isSuperadmin();
    }

    // Subcolección: contactos por cliente
    match /clientes/{clienteId}/contactos/{contactoId} {
      allow read: if canColab();
      allow create: if canColab();
      allow update: if canColab();
      allow delete: if canColab();
    }

    // =========================
    // ESTADO DE RESULTADOS (metadata)
    // =========================

    match /eerr/{docId} {

      // Todos los autenticados pueden leer (para ver fecha/autor de la última subida)
      allow read: if isLogged();

      // Solo superadmin puede escribir (registrar una nueva subida)
      allow write: if isSuperadmin();
    }

    // =========================
    // DFE tracking interno (metadata del estudio)
    // =========================

    match /dfe_tracking/{docId} {
      allow read: if canColab();
      allow create: if canColab();
      allow update: if canColab();
      allow delete: if isAdmin();
    }

    // =========================
    // DFE inbox (datos externos ARCA/AFIP persistidos)
    // =========================

    // Legacy: config de clientes solo en DFE (migración). La fuente principal es `clientes` + dfeEnabled.
    // DocID recomendado: CUIT (11 dígitos).
    match /dfe_clients/{cuit} {
      allow read: if canColab();
      // Configuración: solo admin/superadmin.
      allow create, update, delete: if isAdmin();
    }

    // Comunicaciones DFE persistidas (solo lectura desde frontend; escritura la hace el backend).
    // DocID recomendado: {cuitRepresentada}__{idComunicacion}
    match /dfe_comunicaciones/{docId} {
      allow read: if canColab();
      allow write: if false;
    }

    // =========================
    // Colaboración transversal (metadata interna por módulo + entidad)
    // Doc ID: {moduleId}__{entityKey}  ej. dfe__20279722796__610201380
    //
    // Seguridad:
    // - Lectura/escritura: solo roles colaborativos (superadmin / admin / colaborador).
    // - "lectura" u otros roles: NO pasan canColab() → sin acceso.
    // - Permisos por pantalla (ej. módulo DFE) los aplica la app; aquí no se discrimina moduleId.
    //
    // Create: exigimos moduleId + entityKey + schemaVersion para evitar docs basura;
    // los updates suelen ser merge parcial y pueden omitir esos campos.
    // =========================

    match /att_collaboration/{docId} {
      allow read: if canColab();

      allow create: if canColab()
        && request.resource.data.moduleId is string
        && request.resource.data.entityKey is string
        && request.resource.data.schemaVersion is int;

      allow update: if canColab();

      allow delete: if isAdmin();
    }
  }
}
