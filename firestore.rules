rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /requirements/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /users/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Clientes + subcolecciones (por ejemplo: /clientes/{id}/contactos/*)
    match /clientes/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Trazabilidad de cumplimientos (cumplimentación de tareas/obligaciones)
    match /cumplimientos/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /operaciones/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
